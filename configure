#!/bin/bash

# Verify build dependencies for CimpleOS build

# List of required tools
required_tools=(gcc nasm ld grub-mkrescue)

# Check for each required tool
for tool in "${required_tools[@]}"; do
    if ! command -v $tool &> /dev/null; then
        echo "$tool is not installed. Please install it and try again."
        exit 1
    fi
done

echo "All required tools are installed."
echo "Setting up the environment for the CimpleOS build..."

# Additional environment setup commands can go here
# e.g., export PATH=... or config settings

echo "Environment setup completed."